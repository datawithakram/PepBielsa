API_FOOTBALL_KEY=your_api_football_key
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key  # optional
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
HF_TOKEN=your_huggingface_token
HF_USERNAME=your_hf_username
HF_DATASET_REPO=your_hf_username/tactical-storage

# News Feed System
NEWS_CHANNEL_ID=-100xxxxxxxxxx   # Channel or group to broadcast news (use numeric ID)
ADMIN_CHAT_ID=your_telegram_user_id  # Your personal chat ID (for /reset_news)
NEWS_POLL_MINUTES=30              # How often to fetch regular news (default: 30)
BREAKING_POLL_MINUTES=10          # How often to check for breaking news (default: 10)
NEWS_MAX_PER_CAT=3               # Max articles per category per cycle
NEWS_MAX_BREAKING=5              # Max breaking news alerts per cycle